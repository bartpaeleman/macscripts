#!/bin/bash

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "Dit is een master wrapper script."
    echo ""
    echo "Beschikbare tools in dit menu:"
    echo -e "Network Master Tools
  (Interactieve netwerk tools)"
    echo ""
    echo "Gebruik zonder argumenten om het interactieve menu te starten."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for NETWORK tools

NETWORK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/NETWORK" && pwd)"

exec "$NETWORK_DIR/network-master.sh" "$@"
