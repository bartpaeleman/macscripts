#!/bin/bash

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "Dit is een master wrapper script."
    echo ""
    echo "Beschikbare tools in dit menu:"
    echo -e "Data Master Tool
  1) View CSV
  2) Convert Delimiter
  3) Convert Format
  4) Normalize CSV"
    echo ""
    echo "Gebruik zonder argumenten om het interactieve menu te starten."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for DATA tools

DATA_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/DATA" && pwd)"

exec "$DATA_DIR/data-master.sh" "$@"
