# ============================================================
# GIT MASTER - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!
# Add .env to your .gitignore file

# --- GITHUB AUTHENTICATION ---
GITHUB_TOKEN=""                    # Your GitHub Personal Access Token
GITHUB_USERNAME=""                 # Your GitHub username

# --- PATH CONFIGURATION ---
# Base path for all web projects
PATH_ROOT="/share/Web"             # QNAP: /share/Web | Mac: ~/Projects

# Automatically derived paths (optional override)
# PATH_PROD="${PATH_ROOT}"
# PATH_DEV="${PATH_ROOT}/DEV"
# PATH_TEST="${PATH_ROOT}/TEST"

# --- SCRIPT PERSISTENCE (QNAP only) ---
# PERSISTENT_SCRIPT_PATH="${PATH_DEV}/scripts/git-master.sh"
# PERSISTENT_ENV="${PATH_DEV}/scripts/.env"

# --- OPTIONAL SETTINGS ---
# DEFAULT_BRANCH="main"            # Default branch name
# AUTO_PRUNE=true                  # Auto-prune on fetch
