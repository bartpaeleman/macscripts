#!/bin/bash

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "Dit is een master wrapper script."
    echo ""
    echo "Beschikbare tools in dit menu:"
    echo -e "Script Master Control Panel
  (Centrale hub voor alle tools)"
    echo ""
    echo "Gebruik zonder argumenten om het interactieve menu te starten."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for SCRIPT tools

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/SCRIPT" && pwd)"

exec "$SCRIPT_DIR/script-master.sh" "$@"
