#!/bin/bash
# Master Wrapper Script for SCRIPT tools


if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "Usage: $0 [options]"
    echo "This is a master wrapper script. Run without arguments for the interactive menu."
    exit 0
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/SCRIPT" && pwd)"

exec "$SCRIPT_DIR/script-master.sh" "$@"
