#!/bin/bash

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "Dit is een master wrapper script."
    echo ""
    echo "Beschikbare tools in dit menu:"
    echo -e "Text Master Tools
  (Interactieve tekst bewerking)"
    echo ""
    echo "Gebruik zonder argumenten om het interactieve menu te starten."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for TEXT tools

TEXT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/TEXT" && pwd)"

exec "$TEXT_DIR/text-master.sh" "$@"
