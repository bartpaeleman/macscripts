#!/bin/bash

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "Dit is een master wrapper script."
    echo ""
    echo "Beschikbare tools in dit menu:"
    echo -e "Container Master Control Panel
  (Interactieve Docker management)"
    echo ""
    echo "Gebruik zonder argumenten om het interactieve menu te starten."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for CONTAINER tools

CONTAINER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/CONTAINER" && pwd)"

# Defer to the actual interactive script
exec "$CONTAINER_DIR/container-master.sh" "$@"
