#!/bin/bash
# Master Wrapper Script for FILE tools


if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "Usage: $0 [options]"
    echo "This is a master wrapper script. Run without arguments for the interactive menu."
    exit 0
fi

FILE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/FILE" && pwd)"

exec "$FILE_DIR/file-master.sh" "$@"
