#!/bin/bash

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "Dit is een master wrapper script."
    echo ""
    echo "Beschikbare tools in dit menu:"
    echo -e "File Master Tool
  1) Bulk Rename
  2) Create Structure
  3) Archive
  4) Cleanup
  5) Compare Files"
    echo ""
    echo "Gebruik zonder argumenten om het interactieve menu te starten."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for FILE tools

FILE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/FILE" && pwd)"

exec "$FILE_DIR/file-master.sh" "$@"
