#!/bin/bash

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "Dit is een master wrapper script."
    echo ""
    echo "Beschikbare tools in dit menu:"
    echo -e "Web Scaffold Tool
  (Genereert web projecten)"
    echo ""
    echo "Gebruik zonder argumenten om het interactieve menu te starten."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for WEB tools

WEB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/WEB" && pwd)"

exec "$WEB_DIR/scaffold.sh" "$@"
