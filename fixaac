#!/bin/bash

# MP4 Audio Fixer: Converteert MP3-audio in MP4-containers naar AAC voor macOS compatibiliteit
# Video wordt NIET opnieuw gecodeerd (blijft intact en snel), audio krijgt AAC encoding.
# Ultra-robuust voor netwerkschijven (NAS), vreemde spaties en speciale tekens.

if ! command -v ffmpeg &> /dev/null || ! command -v ffprobe &> /dev/null; then
    echo "Fout: ffmpeg of ffprobe is niet geïnstalleerd. Installeer ze eerst met: brew install ffmpeg"
    exit 1
fi

# Bepaal de doelmap (argument 1, of de huidige map indien leeg)
TARGET_DIR="${1:-.}"

if [ ! -d "$TARGET_DIR" ]; then
    echo "Fout: Map '$TARGET_DIR' bestaat niet."
    exit 1
fi

# We maken de functie beschikbaar voor 'find' door deze te exporteren
fix_mp4_audio() {
    local input_file="$1"
    
    # Weiger lege input of onzichtbare AppleDouble bestanden direct
    [[ -z "$input_file" ]] && return 1
    [[ "$(basename "$input_file")" == ._* ]] && return 1

    local dir_path=$(dirname "$input_file")
    local filename=$(basename "$input_file")
    local temp_file="${dir_path}/temp_aac_${filename}"

    echo ""
    echo "=== Controleren: $filename ==="

    # Controleer het audioformaat met een volledig geïsoleerde ffprobe aanroep
    local audio_codec
    audio_codec=$(ffprobe -v error -select_streams a:0 -show_entries stream=codec_name -of default=noprint_wrappers=1:nokey=1 "$input_file" 2>/dev/null)

    if [ -z "$audio_codec" ]; then
        echo "    → Geen audiostream gevonden of pad-fout, overslaan..."
        return 1
    fi

    # Schoon de codec string op
    audio_codec=$(echo "$audio_codec" | tr -d '[:space:]')

    if [ "$audio_codec" != "mp3" ]; then
        echo "    → Audio is al '$audio_codec' (geen MP3), overslaan..."
        return 2
    fi

    echo "    → MP3 audio gedetecteerd! Converteren naar AAC..."

    # Converteer audio naar AAC, kopieer video stream
    if ffmpeg -hide_banner -loglevel error -i "$input_file" -c:v copy -c:a aac -b:a 192k -y "$temp_file" 2>/dev/null; then
        if [ -f "$temp_file" ] && [ -s "$temp_file" ]; then
            mv "$temp_file" "$input_file"
            echo "    ✓ Succesvol vervangen door AAC versie!"
            return 0
        fi
    fi

    echo "    ✗ Conversie mislukt voor dit bestand. Origineel blijft ongewijzigd."
    rm -f "$temp_file"
    return 3
}

# Exporteer de functie zodat 'find' erbij kan
export -f fix_mp4_audio

# Hoofdscript
echo "MP4 MP3-naar-AAC Audio Fixer (NAS & Special Characters Safe)"
echo "==========================================================="
echo "Doelmap: $(cd "$TARGET_DIR" && pwd)"
echo "Start tijd: $(date)"
echo ""

# Tel het aantal bestanden vooraf
file_count=$(find "$TARGET_DIR" -iname "*.mp4" -not -name "._*" -type f | wc -l | tr -d ' ')
echo "Aantal gevonden echte MP4-bestanden om te analyseren: $file_count"
echo "--------------------------------------------------"

if [ "$file_count" -eq 0 ]; then
    echo "Geen geldige .mp4 bestanden gevonden in deze map."
else
    # Schakel over naar -exec om de bestandspaden 100% intact te houden via het OS naar de functie
    find "$TARGET_DIR" -iname "*.mp4" -not -name "._*" -type f -exec bash -c 'fix_mp4_audio "$0"' {} \;
fi

echo ""
echo "=== VOLTOOID ==="
echo "Controleer de output hierboven voor de resultaten per bestand."
echo "Eind tijd: $(date)"