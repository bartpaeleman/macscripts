#!/bin/bash

# Make sure autocomplete doesn't clutter the screen by clearing it when you press Tab
set -o emacs
bind '"\t": "\C-l\e\e"' 2>/dev/null || true


if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "This is a master wrapper script."
    echo ""
    echo "Tools available in this menu:"
    echo -e "Directory Master
  1) lijst
  2) csvlijst
  3) copy_sync
  4) compare_folders"
    echo ""
    echo "Use without arguments to launch the interactive menu."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for DIRECTORY tools

DIR_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/DIRECTORY" && pwd)"

# Colors
GREEN='\033[1;32m'
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

pause() {
    echo -e "\n${YELLOW}Press Enter to continue...${NC}"
    read -r
}

while true; do
    clear
    echo -e "${CYAN}================================================${NC}"
    echo -e "         ${CYAN}DIRECTORY MASTER CONTROL PANEL${NC}"
    echo -e "${CYAN}================================================${NC}"
    echo -e "${GREEN}Available tools:${NC}"
    echo "1) List files"
    echo "2) List as CSV"
    echo "3) Copy & Sync folders"
    echo "4) Compare folders"
    echo -e "\n${YELLOW}X) Exit${NC}"
    echo -e "${CYAN}================================================${NC}"

    read -p "Select action: " choice

    case "$choice" in
        1)
            echo -e "\n${CYAN}=== Bestanden Lijst Configuratie ===${NC}"

            read -e -p "Wat is de bronmap? [huidige map]: " bronmap < /dev/tty
            bronmap=${bronmap:-.}

            read -e -p "Wat is de doelmap voor het uitvoerbestand? [huidige map]: " doelmap < /dev/tty
            doelmap=${doelmap:-.}

            read -e -p "Welke extensie wil je zoeken? (zonder punt) [mp4]: " extensie < /dev/tty
            extensie=${extensie:-mp4}

            read -e -p "Wat is de naam van het uitvoerbestand? [bestanden_lijst.txt]: " output_file < /dev/tty
            output_file=${output_file:-bestanden_lijst.txt}

            read -e -p "Wil je recursief zoeken in submappen? (j/n) [j]: " recursief
            recursief=${recursief:-j}

            read -e -p "Wil je padinformatie includeren in de lijst? (j/n) [n]: " paths
            paths=${paths:-n}

            read -e -p "Wil je gedetailleerde (verbose) output zien? (j/n) [n]: " verbose
            verbose=${verbose:-n}

            args=("-s" "$bronmap" "-t" "$doelmap" "-e" "$extensie" "-o" "$output_file")
            if [[ "$recursief" =~ ^[nN] ]]; then
                args+=("-n")
            fi
            if [[ "$paths" =~ ^[jJyY] ]]; then
                args+=("-p")
            fi
            if [[ "$verbose" =~ ^[jJyY] ]]; then
                args+=("-v")
            fi

            echo -e "\n${GREEN}Lijst genereren...${NC}"
            "$DIR_DIR/lijst" "${args[@]}"
            pause
            ;;
        2)
            echo -e "\n${CYAN}=== CSV Lijst Configuratie ===${NC}"

            read -e -p "Wat is de bronmap? [huidige map]: " bronmap < /dev/tty
            bronmap=${bronmap:-.}

            read -e -p "Wat is de naam van het uitvoerbestand? [output.csv]: " output_file < /dev/tty
            output_file=${output_file:-output.csv}

            read -e -p "Wil je de Muziek Database modus gebruiken (ARTIEST, TITEL, MAP, etc.)? (j/n) [n]: " muziek
            muziek=${muziek:-n}

            args=("-d" "$bronmap" "-o" "$output_file")

            if [[ "$muziek" =~ ^[jJyY] ]]; then
                args+=("-m")
            else
                echo -e "\nWelke kolommen wil je opnemen in de CSV?"
                read -e -p "  Toon BESTANDSNAAM? (j/n) [j]: " toon_naam
                toon_naam=${toon_naam:-j}
                if [[ "$toon_naam" =~ ^[jJyY] ]]; then args+=("-n"); fi

                read -e -p "  Toon BESTANDSTYPE? (j/n) [j]: " toon_type
                toon_type=${toon_type:-j}
                if [[ "$toon_type" =~ ^[jJyY] ]]; then args+=("-t"); fi

                read -e -p "  Toon BESTANDSGROOTTE? (j/n) [j]: " toon_grootte
                toon_grootte=${toon_grootte:-j}
                if [[ "$toon_grootte" =~ ^[jJyY] ]]; then args+=("-s"); fi

                read -e -p "  Toon VOLLEDIG PAD? (j/n) [n]: " toon_pad
                toon_pad=${toon_pad:-n}
                if [[ "$toon_pad" =~ ^[jJyY] ]]; then args+=("-p"); fi
            fi

            echo ""
            read -e -p "Wil je onzichtbare (hidden) bestanden eruit filteren? (j/n) [j]: " filter_hidden
            filter_hidden=${filter_hidden:-j}
            if [[ "$filter_hidden" =~ ^[jJyY] ]]; then
                args+=("-f")
            fi

            echo -e "\n${GREEN}CSV lijst genereren...${NC}"
            "$DIR_DIR/csvlijst" "${args[@]}"
            pause
            ;;
        3)
            echo -e "${GREEN}Running copy_sync...${NC}"
            read -e -p "Enter arguments (or press enter for interactive): " args < /dev/tty
            eval "\"$DIR_DIR/copy_sync\" $args"
            pause
            ;;
        4)
            echo -e "${GREEN}Running compare_folders...${NC}"
            read -e -p "Enter arguments (or press enter for interactive): " args < /dev/tty
            eval "\"$DIR_DIR/compare_folders\" $args"
            pause
            ;;
        [xX])
            echo -e "${GREEN}Exiting...${NC}"
            clear
            break
            ;;
        *)
            echo -e "${RED}Invalid choice.${NC}"
            pause
            ;;
    esac
done
