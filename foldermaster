#!/bin/bash

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "Dit is een master wrapper script."
    echo ""
    echo "Beschikbare tools in dit menu:"
    echo -e "Directory Master
  1) Folder lijst
  2) Folder CSV lijst
  3) Copy of Synch Folders
  4) Vergelijk Folders"
    echo ""
    echo "Gebruik zonder argumenten om het interactieve menu te starten."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for DIRECTORY tools

DIR_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/DIRECTORY" && pwd)"

# Colors
GREEN='\033[1;32m'
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

pause() {
    echo -e "\n${YELLOW}Press Enter to continue...${NC}"
    read -r
}

while true; do
    clear
    echo -e "${CYAN}================================================${NC}"
    echo -e "         ${CYAN}DIRECTORY MASTER CONTROL PANEL${NC}"
    echo -e "${CYAN}================================================${NC}"
    echo -e "${GREEN}Available tools:${NC}"
    echo "1) Folder lijst"
    echo "2) Folder CSV lijst"
    echo "3) Copy of Sync Folders"
    echo "4) Vergelijk Folders"
    echo -e "\n${YELLOW}X) Exit${NC}"
    echo -e "${CYAN}================================================${NC}"

    read -p "Select action: " choice

    case "$choice" in
        1)
            echo -e "${GREEN}Running lijst...${NC}"
            read -e -p "Geef argumenten: " args
            eval "\"$DIR_DIR/lijst\" $args"
            pause
            ;;
        2)
            echo -e "${GREEN}Running csvlijst...${NC}"
            read -e -p "Geef argumenten: " args
            eval "\"$DIR_DIR/csvlijst\" $args"
            pause
            ;;
        3)
            echo -e "${GREEN}Running copy_sync...${NC}"
            read -e -p "Geef argumenten (of druk enter voor interactief): " args
            eval "\"$DIR_DIR/copy_sync\" $args"
            pause
            ;;
        4)
            echo -e "${GREEN}Running compare_folders...${NC}"
            read -e -p "Geef argumenten (of druk enter voor interactief): " args
            eval "\"$DIR_DIR/compare_folders\" $args"
            pause
            ;;
        [xX])
            echo -e "${GREEN}Exiting...${NC}"
            break
            ;;
        *)
            echo -e "${RED}Invalid choice.${NC}"
            pause
            ;;
    esac
done
