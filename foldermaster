#!/bin/bash
# Master Wrapper Script for DIRECTORY tools


if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "Usage: $0 [options]"
    echo "This is a master wrapper script. Run without arguments for the interactive menu."
    exit 0
fi

DIR_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/DIRECTORY" && pwd)"

# Colors
GREEN='\033[1;32m'
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

pause() {
    echo -e "\n${YELLOW}Press Enter to continue...${NC}"
    read -r
}

while true; do
    clear
    echo -e "${CYAN}================================================${NC}"
    echo -e "         ${CYAN}DIRECTORY MASTER CONTROL PANEL${NC}"
    echo -e "${CYAN}================================================${NC}"
    echo -e "${GREEN}Available tools:${NC}"
    echo "1) lijst"
    echo "2) csvlijst"
    echo "3) copy_sync"
    echo -e "\n${YELLOW}X) Exit${NC}"
    echo -e "${CYAN}================================================${NC}"

    read -p "Select action: " choice

    case "$choice" in
        1)
            echo -e "${GREEN}Running lijst...${NC}"
            read -e -p "Enter arguments for lijst: " args
            eval "\"$DIR_DIR/lijst\" $args"
            pause
            ;;
        2)
            echo -e "${GREEN}Running csvlijst...${NC}"
            read -e -p "Enter arguments for csvlijst: " args
            eval "\"$DIR_DIR/csvlijst\" $args"
            pause
            ;;
        3)
            echo -e "${GREEN}Running copy_sync...${NC}"
            read -e -p "Enter arguments for copy_sync (or press enter for interactive): " args
            eval "\"$DIR_DIR/copy_sync\" $args"
            pause
            ;;
        [xX])
            echo -e "${GREEN}Exiting...${NC}"
            break
            ;;
        *)
            echo -e "${RED}Invalid choice.${NC}"
            pause
            ;;
    esac
done
