#!/bin/bash

# Make sure autocomplete doesn't clutter the screen by clearing it when you press Tab
set -o emacs
bind '"\t": "\C-l\e\e"' 2>/dev/null || true


if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "This is a master wrapper script."
    echo ""
    echo "Tools available in this menu:"
    echo -e "Directory Master
  1) lijst
  2) csvlijst
  3) copy_sync
  4) compare_folders"
    echo ""
    echo "Use without arguments to launch the interactive menu."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for DIRECTORY tools

DIR_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/DIRECTORY" && pwd)"

# Colors
GREEN='\033[1;32m'
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

pause() {
    echo -e "\n${YELLOW}Press Enter to continue...${NC}"
    read -r
}

while true; do
    clear
    echo -e "${CYAN}================================================${NC}"
    echo -e "         ${CYAN}DIRECTORY MASTER CONTROL PANEL${NC}"
    echo -e "${CYAN}================================================${NC}"
    echo -e "${GREEN}Available tools:${NC}"
    echo "1) List files"
    echo "2) List as CSV"
    echo "3) Copy & Sync folders"
    echo "4) Compare folders"
    echo -e "\n${YELLOW}X) Exit${NC}"
    echo -e "${CYAN}================================================${NC}"

    read -p "Select action: " choice

    case "$choice" in
        1)
            bronmap="."
            doelmap="."
            extensie="mp4"
            output_file="bestanden_lijst.txt"
            recursief="j"
            paths="n"
            verbose="n"

            while true; do
                clear
                echo -e "${CYAN}=== Bestanden Lijst Configuratie ===${NC}"
                echo "Pas de instellingen aan en typ 'S' om te starten."
                echo ""
                echo -e "1) Bronmap:          ${YELLOW}$bronmap${NC}"
                echo -e "2) Doelmap:          ${YELLOW}$doelmap${NC}"
                echo -e "3) Extensie:         ${YELLOW}$extensie${NC}"
                echo -e "4) Uitvoerbestand:   ${YELLOW}$output_file${NC}"
                echo -e "5) Recursief:        ${YELLOW}$recursief${NC} (j/n)"
                echo -e "6) Toon paden:       ${YELLOW}$paths${NC} (j/n)"
                echo -e "7) Verbose modus:    ${YELLOW}$verbose${NC} (j/n)"
                echo ""
                echo -e "${GREEN}S) START met deze instellingen${NC}"
                echo -e "${RED}0) Annuleren en terug naar menu${NC}"
                echo ""
                read -e -p "Keuze: " config_choice

                case "$config_choice" in
                    1) read -e -p "Nieuwe bronmap: " input; if [ -n "$input" ]; then bronmap="$input"; fi ;;
                    2) read -e -p "Nieuwe doelmap: " input; if [ -n "$input" ]; then doelmap="$input"; fi ;;
                    3) read -e -p "Nieuwe extensie (zonder punt): " input; if [ -n "$input" ]; then extensie="$input"; fi ;;
                    4) read -e -p "Nieuwe uitvoerbestand naam: " input; if [ -n "$input" ]; then output_file="$input"; fi ;;
                    5) read -e -p "Recursief (j/n): " input; if [[ "$input" =~ ^[jJnNyY]$ ]]; then recursief="$input"; fi ;;
                    6) read -e -p "Toon paden (j/n): " input; if [[ "$input" =~ ^[jJnNyY]$ ]]; then paths="$input"; fi ;;
                    7) read -e -p "Verbose (j/n): " input; if [[ "$input" =~ ^[jJnNyY]$ ]]; then verbose="$input"; fi ;;
                    [sS])
                        args=("-s" "$bronmap" "-t" "$doelmap" "-e" "$extensie" "-o" "$output_file")
                        if [[ "$recursief" =~ ^[nN] ]]; then args+=("-n"); fi
                        if [[ "$paths" =~ ^[jJyY] ]]; then args+=("-p"); fi
                        if [[ "$verbose" =~ ^[jJyY] ]]; then args+=("-v"); fi

                        echo -e "\n${GREEN}Lijst genereren...${NC}"
                        "$DIR_DIR/lijst" "${args[@]}"
                        pause
                        break
                        ;;
                    0) break ;;
                    *) echo -e "${RED}Ongeldige keuze.${NC}"; sleep 1 ;;
                esac
            done
            ;;
        2)
            bronmap="."
            output_file="output.csv"
            muziek="n"
            toon_naam="j"
            toon_type="j"
            toon_grootte="j"
            toon_pad="n"
            filter_hidden="j"

            while true; do
                clear
                echo -e "${CYAN}=== CSV Lijst Configuratie ===${NC}"
                echo "Pas de instellingen aan en typ 'S' om te starten."
                echo ""
                echo -e "1) Bronmap:              ${YELLOW}$bronmap${NC}"
                echo -e "2) Uitvoerbestand:       ${YELLOW}$output_file${NC}"
                echo -e "3) Filter hidden:        ${YELLOW}$filter_hidden${NC} (j/n)"
                echo -e "4) Muziek DB modus:      ${YELLOW}$muziek${NC} (j/n)"
                if [[ "$muziek" =~ ^[nN] ]]; then
                    echo -e "\nKolommen om te tonen:"
                    echo -e "5) Toon Bestandsnaam:    ${YELLOW}$toon_naam${NC} (j/n)"
                    echo -e "6) Toon Bestandstype:    ${YELLOW}$toon_type${NC} (j/n)"
                    echo -e "7) Toon Bestandsgrootte: ${YELLOW}$toon_grootte${NC} (j/n)"
                    echo -e "8) Toon Volledig Pad:    ${YELLOW}$toon_pad${NC} (j/n)"
                fi
                echo ""
                echo -e "${GREEN}S) START met deze instellingen${NC}"
                echo -e "${RED}0) Annuleren en terug naar menu${NC}"
                echo ""
                read -e -p "Keuze: " config_choice

                case "$config_choice" in
                    1) read -e -p "Nieuwe bronmap: " input; if [ -n "$input" ]; then bronmap="$input"; fi ;;
                    2) read -e -p "Nieuwe uitvoerbestand naam: " input; if [ -n "$input" ]; then output_file="$input"; fi ;;
                    3) read -e -p "Filter hidden files (j/n): " input; if [[ "$input" =~ ^[jJnNyY]$ ]]; then filter_hidden="$input"; fi ;;
                    4) read -e -p "Muziek DB modus (j/n): " input; if [[ "$input" =~ ^[jJnNyY]$ ]]; then muziek="$input"; fi ;;
                    5) if [[ "$muziek" =~ ^[nN] ]]; then read -e -p "Toon Bestandsnaam (j/n): " input; if [[ "$input" =~ ^[jJnNyY]$ ]]; then toon_naam="$input"; fi; fi ;;
                    6) if [[ "$muziek" =~ ^[nN] ]]; then read -e -p "Toon Bestandstype (j/n): " input; if [[ "$input" =~ ^[jJnNyY]$ ]]; then toon_type="$input"; fi; fi ;;
                    7) if [[ "$muziek" =~ ^[nN] ]]; then read -e -p "Toon Bestandsgrootte (j/n): " input; if [[ "$input" =~ ^[jJnNyY]$ ]]; then toon_grootte="$input"; fi; fi ;;
                    8) if [[ "$muziek" =~ ^[nN] ]]; then read -e -p "Toon Volledig Pad (j/n): " input; if [[ "$input" =~ ^[jJnNyY]$ ]]; then toon_pad="$input"; fi; fi ;;
                    [sS])
                        args=("-d" "$bronmap" "-o" "$output_file")

                        if [[ "$muziek" =~ ^[jJyY] ]]; then
                            args+=("-m")
                        else
                            if [[ "$toon_naam" =~ ^[jJyY] ]]; then args+=("-n"); fi
                            if [[ "$toon_type" =~ ^[jJyY] ]]; then args+=("-t"); fi
                            if [[ "$toon_grootte" =~ ^[jJyY] ]]; then args+=("-s"); fi
                            if [[ "$toon_pad" =~ ^[jJyY] ]]; then args+=("-p"); fi
                        fi

                        if [[ "$filter_hidden" =~ ^[jJyY] ]]; then
                            args+=("-f")
                        fi

                        echo -e "\n${GREEN}CSV lijst genereren...${NC}"
                        "$DIR_DIR/csvlijst" "${args[@]}"
                        pause
                        break
                        ;;
                    0) break ;;
                    *) echo -e "${RED}Ongeldige keuze.${NC}"; sleep 1 ;;
                esac
            done
            ;;
        3)
            echo -e "${GREEN}Running copy_sync...${NC}"
            read -e -p "Enter arguments (or press enter for interactive): " args
            eval "\"$DIR_DIR/copy_sync\" $args"
            pause
            ;;
        4)
            echo -e "${GREEN}Running compare_folders...${NC}"
            read -e -p "Enter arguments (or press enter for interactive): " args
            eval "\"$DIR_DIR/compare_folders\" $args"
            pause
            ;;
        [xX])
            echo -e "${GREEN}Exiting...${NC}"
            clear
            break
            ;;
        *)
            echo -e "${RED}Invalid choice.${NC}"
            pause
            ;;
    esac
done
