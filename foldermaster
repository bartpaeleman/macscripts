#!/bin/bash

# Make sure autocomplete doesn't clutter the screen by clearing it when you press Tab
set -o emacs
# Removed custom bind because \C-l breaks readline rendering inside persistent while loops
# bind '"\t": "\C-l\e\e"' 2>/dev/null || true


if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "This is a master wrapper script."
    echo ""
    echo "Tools available in this menu:"
    echo -e "Directory Master
  1) lijst
  2) csvlijst
  3) copy_sync
  4) compare_folders"
    echo ""
    echo "Use without arguments to launch the interactive menu."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for DIRECTORY tools

DIR_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/DIRECTORY" && pwd)"

# Colors
GREEN='\033[1;32m'
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

pause() {
    echo -e "\n${YELLOW}Press Enter to continue...${NC}"
    read -r
}

read_with_default() {
    local prompt="$1"
    local default="$2"
    local var_name="$3"
    local temp_var=""

    if [ "${BASH_VERSINFO[0]:-3}" -ge 4 ]; then
        read -e -i "$default" -p "$prompt" temp_var < /dev/tty
    else
        echo -ne "$prompt [$default]: "
        read -e temp_var < /dev/tty
    fi

    if [ -n "$temp_var" ]; then
        eval "$var_name=\"\$temp_var\""
    fi
}

while true; do
    clear
    echo -e "${CYAN}================================================${NC}"
    echo -e "         ${CYAN}DIRECTORY MASTER CONTROL PANEL${NC}"
    echo -e "${CYAN}================================================${NC}"
    echo -e "${GREEN}Available tools:${NC}"
    echo "1) List files"
    echo "2) List as CSV"
    echo "3) Copy & Sync folders"
    echo "4) Compare folders"
    echo -e "\n${YELLOW}X) Exit${NC}"
    echo -e "${CYAN}================================================${NC}"

    read -p "Select action: " choice

    case "$choice" in
        1)
            bronmap="."
            doelmap="."
            extensie="*"
            output_file="bestanden_lijst.txt"
            recursief="y"
            paths="n"
            verbose="n"

            while true; do
                clear
                echo -e "${CYAN}=== File List Configuration ===${NC}"
                echo "Adjust the settings below and type 'S' to start."
                echo ""
                echo -e "1) Source Dir:       ${YELLOW}$bronmap${NC}"
                echo -e "2) Target Dir:       ${YELLOW}$doelmap${NC}"
                echo -e "3) Extension:        ${YELLOW}$extensie${NC}"
                echo -e "4) Output File:      ${YELLOW}$output_file${NC}"
                echo -e "5) Recursive:        ${YELLOW}$recursief${NC} (y/n)"
                echo -e "6) Show Paths:       ${YELLOW}$paths${NC} (y/n)"
                echo -e "7) Verbose Mode:     ${YELLOW}$verbose${NC} (y/n)"
                echo ""
                echo -e "${GREEN}S) START with these settings${NC}"
                echo -e "${RED}0) Back${NC}"
                echo ""
                read -e -p "Choice: " config_choice

                case "$config_choice" in
                    1) read_with_default "  New Source Dir: " "$bronmap" bronmap ;;
                    2) read_with_default "  New Target Dir: " "$doelmap" doelmap ;;
                    3) read_with_default "  New Extension (no dot, or * for all): " "$extensie" extensie ;;
                    4) read_with_default "  New Output File: " "$output_file" output_file ;;
                    5) read_with_default "  Recursive (y/n): " "$recursief" recursief ;;
                    6) read_with_default "  Show Paths (y/n): " "$paths" paths ;;
                    7) read_with_default "  Verbose (y/n): " "$verbose" verbose ;;
                    [sS])
                        args=("-s" "$bronmap" "-t" "$doelmap" "-e" "$extensie" "-o" "$output_file")
                        if [[ "$recursief" =~ ^[nN] ]]; then args+=("-n"); fi
                        if [[ "$paths" =~ ^[yY] ]]; then args+=("-p"); fi
                        if [[ "$verbose" =~ ^[yY] ]]; then args+=("-v"); fi

                        echo -e "\n${GREEN}Generating list...${NC}"
                        "$DIR_DIR/lijst" "${args[@]}"
                        pause
                        break
                        ;;
                    0) break ;;
                    *) echo -e "${RED}Invalid choice.${NC}"; sleep 1 ;;
                esac
            done
            ;;
        2)
            bronmap="."
            output_file="output.csv"
            muziek="n"
            toon_naam="y"
            toon_type="y"
            toon_grootte="y"
            toon_pad="n"
            filter_hidden="y"

            while true; do
                clear
                echo -e "${CYAN}=== CSV List Configuration ===${NC}"
                echo "Adjust the settings below and type 'S' to start."
                echo ""
                echo -e "1) Source Dir:           ${YELLOW}$bronmap${NC}"
                echo -e "2) Output File:          ${YELLOW}$output_file${NC}"
                echo -e "3) Filter Hidden:        ${YELLOW}$filter_hidden${NC} (y/n)"
                echo -e "4) Music DB Mode:        ${YELLOW}$muziek${NC} (y/n)"
                if [[ "$muziek" =~ ^[nN] ]]; then
                    echo -e "\nColumns to include:"
                    echo -e "5) Show Filename:        ${YELLOW}$toon_naam${NC} (y/n)"
                    echo -e "6) Show Filetype:        ${YELLOW}$toon_type${NC} (y/n)"
                    echo -e "7) Show File Size:       ${YELLOW}$toon_grootte${NC} (y/n)"
                    echo -e "8) Show Full Path:       ${YELLOW}$toon_pad${NC} (y/n)"
                fi
                echo ""
                echo -e "${GREEN}S) START with these settings${NC}"
                echo -e "${RED}0) Back${NC}"
                echo ""
                read -e -p "Choice: " config_choice

                case "$config_choice" in
                    1) read_with_default "  New Source Dir: " "$bronmap" bronmap ;;
                    2) read_with_default "  New Output File: " "$output_file" output_file ;;
                    3) read_with_default "  Filter hidden files (y/n): " "$filter_hidden" filter_hidden ;;
                    4) read_with_default "  Music DB Mode (y/n): " "$muziek" muziek ;;
                    5) if [[ "$muziek" =~ ^[nN] ]]; then read_with_default "  Show Filename (y/n): " "$toon_naam" toon_naam; fi ;;
                    6) if [[ "$muziek" =~ ^[nN] ]]; then read_with_default "  Show Filetype (y/n): " "$toon_type" toon_type; fi ;;
                    7) if [[ "$muziek" =~ ^[nN] ]]; then read_with_default "  Show File Size (y/n): " "$toon_grootte" toon_grootte; fi ;;
                    8) if [[ "$muziek" =~ ^[nN] ]]; then read_with_default "  Show Full Path (y/n): " "$toon_pad" toon_pad; fi ;;
                    [sS])
                        args=("-d" "$bronmap" "-o" "$output_file")

                        if [[ "$muziek" =~ ^[yY] ]]; then
                            args+=("-m")
                        else
                            if [[ "$toon_naam" =~ ^[yY] ]]; then args+=("-n"); fi
                            if [[ "$toon_type" =~ ^[yY] ]]; then args+=("-t"); fi
                            if [[ "$toon_grootte" =~ ^[yY] ]]; then args+=("-s"); fi
                            if [[ "$toon_pad" =~ ^[yY] ]]; then args+=("-p"); fi
                        fi

                        if [[ "$filter_hidden" =~ ^[yY] ]]; then
                            args+=("-f")
                        fi

                        echo -e "\n${GREEN}Generating CSV list...${NC}"
                        "$DIR_DIR/csvlijst" "${args[@]}"
                        pause
                        break
                        ;;
                    0) break ;;
                    *) echo -e "${RED}Invalid choice.${NC}"; sleep 1 ;;
                esac
            done
            ;;
        3)
            echo -e "${GREEN}Running copy_sync...${NC}"
            read -e -p "Enter arguments (or press enter for interactive): " args
            eval "\"$DIR_DIR/copy_sync\" $args"
            pause
            ;;
        4)
            echo -e "${GREEN}Running compare_folders...${NC}"
            read -e -p "Enter arguments (or press enter for interactive): " args
            eval "\"$DIR_DIR/compare_folders\" $args"
            pause
            ;;
        [xX])
            echo -e "${GREEN}Exiting...${NC}"
            clear
            break
            ;;
        *)
            echo -e "${RED}Invalid choice.${NC}"
            pause
            ;;
    esac
done
