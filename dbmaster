#!/bin/bash

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "Dit is een master wrapper script."
    echo ""
    echo "Beschikbare tools in dit menu:"
    echo -e "DB Master Tools
  (Interactieve DB management)"
    echo ""
    echo "Gebruik zonder argumenten om het interactieve menu te starten."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for DB tools

DB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/DB" && pwd)"

exec "$DB_DIR/db-master.sh" "$@"
