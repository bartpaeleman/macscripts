#!/bin/bash

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    echo "=========================================="
    echo "Usage: $0 [options]"
    echo "Dit is een master wrapper script."
    echo ""
    echo "Beschikbare tools in dit menu:"
    echo -e "Threat Intel Tools
  (Interactieve Threat Intel menu)"
    echo ""
    echo "Gebruik zonder argumenten om het interactieve menu te starten."
    echo "=========================================="
    exit 0
fi

# Master Wrapper Script for INTEL tools

INTEL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/INTEL" && pwd)"

exec "$INTEL_DIR/threat-intel.sh" "$@"
