#!/bin/bash
# Master Wrapper Script for VIDEO tools

VIDEO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/VIDEO" && pwd)"

# Colors
GREEN='\033[1;32m'
CYAN='\033[1;36m'
YELLOW='\033[1;33m'
RED='\033[1;31m'
NC='\033[0m'

pause() {
    echo -e "\n${YELLOW}Press Enter to continue...${NC}"
    read -r
}

while true; do
    clear
    echo -e "${CYAN}================================================${NC}"
    echo -e "         ${CYAN}VIDEO MASTER CONTROL PANEL${NC}"
    echo -e "${CYAN}================================================${NC}"
    echo -e "${GREEN}Available tools:${NC}"
    echo "1) 16-9-convert"
    echo "2) combineAV"
    echo -e "\n${YELLOW}X) Exit${NC}"
    echo -e "${CYAN}================================================${NC}"

    read -p "Select action: " choice

    case "$choice" in
        1)
            echo -e "${GREEN}Running 16-9-convert...${NC}"
            "$VIDEO_DIR/16-9-convert"
            pause
            ;;
        2)
            echo -e "${GREEN}Running combineAV...${NC}"
            "$VIDEO_DIR/combineAV"
            pause
            ;;
        [xX])
            echo -e "${GREEN}Exiting...${NC}"
            break
            ;;
        *)
            echo -e "${RED}Invalid choice.${NC}"
            pause
            ;;
    esac
done
