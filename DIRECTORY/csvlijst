#!/usr/bin/env bash
# === Directory naar CSV Generator ===

set -euo pipefail

# Standaardwaarden
SHOW_ALL=true
SHOW_NAAM=false
SHOW_TYPE=false
SHOW_SIZE=false
SHOW_PATH=false
FILTER_HIDDEN=false
MUZIEK_DATABASE=false
UITVOER_BESTAND="output.csv"
BRONMAP="$(pwd)"

# Argumenten verwerken
while [[ $# -gt 0 ]]; do
    case "${1:-}" in
        -n) SHOW_NAAM=true; SHOW_ALL=false ;;
        -t) SHOW_TYPE=true; SHOW_ALL=false ;;
        -s) SHOW_SIZE=true; SHOW_ALL=false ;;
        -p) SHOW_PATH=true; SHOW_ALL=false ;;
        -f) FILTER_HIDDEN=true ;;
        -m) MUZIEK_DATABASE=true; SHOW_ALL=false ;;
        -o)
            if [[ -n "${2:-}" ]]; then
                UITVOER_BESTAND="$2"
                shift
            else
                echo "❌ -o vereist een bestandsnaam/locatie"
                exit 1
            fi
            ;;
        -d)
            if [[ -n "${2:-}" ]]; then
                BRONMAP="$2"
                shift
            else
                echo "❌ -d vereist een map"
                exit 1
            fi
            ;;
        -h|--help)
            echo "Gebruik: $0 [opties]"
            echo "Opties:"
            echo "  -n    Toon NAAM BESTAND"
            echo "  -t    Toon TYPE BESTAND"
            echo "  -s    Toon GROOTTE BESTAND"
            echo "  -p    Toon PATH"
            echo "  -f    Filter onzichtbare bestanden eruit"
            echo "  -m    Muziek database modus (ARTIEST, TITEL, GROOTTE, MAP...)"
            echo "  -o    Uitvoerbestand (standaard: output.csv)"
            echo "  -d    Bronmap (standaard: huidige map)"
            exit 0
            ;;
        *)
            echo "❌ Onbekende optie: ${1:-}"
            exit 1
            ;;
    esac
    shift
done

# --- Pad correcties ---
# Verwerk situaties waarbij -p aan het einde van een string is geplakt of backslashes voorkomen
if [[ ! -d "$BRONMAP" ]]; then
    if [[ "$BRONMAP" == *-p ]]; then
        test_map="${BRONMAP%-p}"
        test_map_clean="${test_map//\\ / }"
        if [[ -d "$test_map_clean" ]]; then
            BRONMAP="$test_map_clean"
            SHOW_PATH=true
            SHOW_ALL=false
        elif [[ -d "$test_map" ]]; then
            BRONMAP="$test_map"
            SHOW_PATH=true
            SHOW_ALL=false
        fi
    fi

    if [[ ! -d "$BRONMAP" ]]; then
        test_map_clean="${BRONMAP//\\ / }"
        if [[ -d "$test_map_clean" ]]; then
            BRONMAP="$test_map_clean"
        fi
    fi
fi

# Remove trailing slash to prevent directory depth issues later on
BRONMAP="${BRONMAP%/}"

if $SHOW_ALL; then
    SHOW_NAAM=true
    SHOW_TYPE=true
    SHOW_SIZE=true
    SHOW_PATH=true
fi

if [[ ! -d "$BRONMAP" ]]; then
    echo "❌ Bronmap bestaat niet: $BRONMAP"
    exit 1
fi

# Tijdelijk bestand voor find resultaten
TMP_FILE=$(mktemp -t lijst_csv.XXXXXX)
trap 'rm -f "$TMP_FILE"' EXIT INT TERM

# Zoek bestanden
ABSOLUTE_BRONMAP=$(realpath "$BRONMAP" 2>/dev/null || { cd "$BRONMAP" >/dev/null 2>&1 && pwd; })
echo -e "\n🔍 Zoeken naar bestanden in $ABSOLUTE_BRONMAP..." >&2
if $FILTER_HIDDEN; then
    find "$BRONMAP" -type f ! -name ".*" ! -path "*/.*" | sort > "$TMP_FILE"
else
    find "$BRONMAP" -type f | sort > "$TMP_FILE"
fi

# Tel aantal gevonden bestanden
AANTAL_BESTANDEN=$(wc -l < "$TMP_FILE" 2>/dev/null | tr -d ' ' || echo "0")
if [[ $AANTAL_BESTANDEN -eq 0 ]] || [[ -z "$AANTAL_BESTANDEN" ]]; then
    echo "❌ Geen bestanden gevonden in $BRONMAP" >&2
    exit 1
fi
echo "✅ $AANTAL_BESTANDEN bestanden gevonden. Starten met verwerken..." >&2
echo "" >&2

# Functie om array naar csv regel te converteren
to_csv() {
    local first=true
    for item in "$@"; do
        # Escape quotes en omsluit met quotes
        item=$(echo "$item" | sed 's/"/""/g')
        if $first; then
            printf '"%s"' "$item"
            first=false
        else
            printf ',"%s"' "$item"
        fi
    done
    printf '\n'
}

{
    if $MUZIEK_DATABASE; then
        # Bereken maximale directory diepte voor dynamische kolommen
        max_depth=0
        while IFS= read -r f; do
            [[ -z "$f" ]] && continue
            dir_part="$(dirname "${f#$BRONMAP/}")"
            if [[ "$dir_part" != "." && -n "$dir_part" ]]; then
                depth=$(awk -F"/" '{print NF}' <<< "$dir_part")
                if [[ $depth -gt $max_depth ]]; then
                    max_depth=$depth
                fi
            fi
        done < "$TMP_FILE"

        HEADER=("ARTIEST" "TITEL" "GROOTTE")
        for ((i=1; i<=max_depth; i++)); do
            HEADER+=("MAP $i")
        done
        to_csv "${HEADER[@]}"

        teller=0
        while IFS= read -r bestand; do
            [[ -z "$bestand" ]] && continue

            teller=$((teller + 1))
            # Print progress indicator op stderr
            printf "\r🔄 Verwerken bestand %d van %d..." "$teller" "$AANTAL_BESTANDEN" >&2

            if [[ ! -f "$bestand" ]]; then
                continue
            fi

            ROW=()
            bestandsnaam=$(basename "$bestand")
            base_naam="${bestandsnaam%.*}"

            if [[ "$base_naam" == *" - "* ]]; then
                artiest="${base_naam%% - *}"
                titel="${base_naam#* - }"
            else
                artiest="Onbekend"
                titel="$base_naam"
            fi

            # Grootte bepalen
            if stat --version 2>/dev/null | grep -q 'GNU'; then
                grootte=$(stat -c %s "$bestand")
            else
                grootte=$(stat -f %z "$bestand")
            fi

            ROW+=("$artiest" "$titel" "$grootte")

            dir_part="$(dirname "${bestand#$BRONMAP/}")"
            maps=()
            if [[ "$dir_part" != "." && -n "$dir_part" ]]; then
                IFS='/' read -ra maps <<< "$dir_part"
            fi

            # Vul aan tot max_depth
            for ((i=0; i<max_depth; i++)); do
                if [[ $i -lt ${#maps[@]} ]]; then
                    ROW+=("${maps[$i]}")
                else
                    ROW+=("")
                fi
            done

            to_csv "${ROW[@]}"
        done < "$TMP_FILE"
        printf "\n" >&2
    else
        # Bouw de header
        HEADER=()
        $SHOW_NAAM && HEADER+=("NAAM BESTAND")
        $SHOW_TYPE && HEADER+=("TYPE BESTAND")
        $SHOW_SIZE && HEADER+=("GROOTTE BESTAND")
        $SHOW_PATH && HEADER+=("PATH")

        to_csv "${HEADER[@]}"

        teller=0
        while IFS= read -r bestand; do
            [[ -z "$bestand" ]] && continue

            teller=$((teller + 1))
            # Print progress indicator op stderr
            printf "\r🔄 Verwerken bestand %d van %d..." "$teller" "$AANTAL_BESTANDEN" >&2

            if [[ ! -f "$bestand" ]]; then
                continue
            fi

            ROW=()

            bestandsnaam=$(basename "$bestand")

            # Type (extensie) bepalen
            if [[ "$bestandsnaam" == *.* ]] && [[ "$bestandsnaam" != .* || "$bestandsnaam" == *.*.* ]]; then
                type="${bestandsnaam##*.}"
            else
                type=""
            fi

            # Grootte (macOS en Linux compatibel)
            if stat --version 2>/dev/null | grep -q 'GNU'; then
                grootte=$(stat -c %s "$bestand")
            else
                grootte=$(stat -f %z "$bestand")
            fi

            $SHOW_NAAM && ROW+=("$bestandsnaam")
            $SHOW_TYPE && ROW+=("$type")
            $SHOW_SIZE && ROW+=("$grootte")
            $SHOW_PATH && ROW+=("$bestand")

            to_csv "${ROW[@]}"
        done < "$TMP_FILE"
        printf "\n" >&2
    fi
} > "$UITVOER_BESTAND"

echo -e "\n✅ CSV bestand aangemaakt: $UITVOER_BESTAND" >&2
